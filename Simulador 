const POS_MAP = {GOL:"GOL",DEF:"ZAG",ZAG:"ZAG",MEI:"MEI",ATA:"ATA"};
const ORDEM = ["GOL","ZAG","MEI","ATA"];
const COR_POS = {GOL:"#f59e0b",ZAG:"#3b82f6",MEI:"#10b981",ATA:"#ef4444"};

function ovrTime(t){
  if(!t.jogadores.length) return 0;
  return Math.round(t.jogadores.reduce((s,j)=>s+j.ovr,0)/t.jogadores.length);
}

function simPartida(a,b){
  const fa = ovrTime(a), fb = ovrTime(b);
  const diff = fa - fb;
  const pA = 0.5 + diff*0.012 + (Math.random()-0.5)*0.3;
  const gA = Math.max(0,Math.round(Math.random()*3 + (pA>0.55?0.5:0)));
  const gB = Math.max(0,Math.round(Math.random()*3 + (pA<0.45?0.5:0)));
  return [gA,gB];
}

function gerarMercado(){
  const NOMES = ["Gabriel Silva","Lucas Santos","Matheus Costa","Rafael Lima","Bruno Gomes","Felipe Souza","Diego Rocha","Rodrigo Alves","Thiago Ferreira","Eduardo Pereira","Carlos Mendes","Arthur Vieira","Gustavo Nunes","Caio Ribeiro","Victor Cruz","Pedro Campos","Vinicius Dias","Kaique Pinto","Enzo Melo","Luan Batista"];
  let ni=0;
  const nome=()=>{const n=NOMES[ni%NOMES.length];ni++;return n+(ni>NOMES.length?` ${Math.floor(ni/NOMES.length)}`:"")}
  const mk=(pos,cat,est)=>{
    const ranges={promessa:{1:[64,69],2:[70,74],3:[75,79]},auge:{1:[72,76],2:[77,80],3:[81,84]},veterano:{1:[70,74],2:[75,78],3:[79,82]}};
    const idades={promessa:[17,23],auge:[24,30],veterano:[31,37]};
    const [lo,hi]=ranges[cat][est];
    const ovr=lo+Math.floor(Math.random()*(hi-lo+1));
    const [ilo,ihi]=idades[cat];
    const idade=ilo+Math.floor(Math.random()*(ihi-ilo+1));
    const preco=Math.max(20,Math.round((ovr*0.6+est*15)*(idade<=21?1.4:idade<=30?1.0:0.7)*[0.7,1.0,1.5][est-1]));
    return {jogador:{nome:nome(),posicao:pos,ovr,idade,potencial:est,estatisticas:EST_BASE()},preco,clube_origem:"Mercado",faixa:cat,estrelas:est};
  };
  const mkt={};
  for(const pos of ORDEM){
    mkt[pos]=[];
    for(const cat of ["promessa","auge","veterano"])
      for(const est of [1,2,3])
        mkt[pos].push(mk(pos,cat,est));
  }
  return mkt;
}

function gerarCalendario(times){
  const n=times.length, rodadas=[];
  const ids=[...Array(n).keys()];
  for(let r=0;r<n-1;r++){
    const rodada=[];
    for(let i=0;i<n/2;i++){
      const a=ids[i],b=ids[n-1-i];
      rodada.push([a,b]);
    }
    rodadas.push(rodada);
    ids.splice(1,0,ids.pop());
  }
  // Turno + returno
  return [...rodadas,...rodadas.map(r=>r.map(([a,b])=>[b,a]))];
}


function TelaMercado({times,timesCtrl,onFim}){
  const [fase,setFase]=useState("vendas");
  const [posIdx,setPosIdx]=useState(0);
  const [ctrlIdx,setCtrlIdx]=useState(0);
  const [mkt,setMkt]=useState(()=>gerarMercado());
  const [timesState,setTimesState]=useState(()=>times.map(t=>({...t,jogadores:[...t.jogadores]})));
  const [vendidos,setVendidos]=useState({});
  const [log,setLog]=useState([]);
  const [iaDone,setIaDone]=useState(false);

  const pos=ORDEM[posIdx];
  const ctrlNomes=timesCtrl;
  const ctrlCompradoresPos=ctrlNomes.filter(n=>vendidos[n]===pos);

  function addLog(msg,tipo="ia"){setLog(l=>[{msg,tipo},...l.slice(0,39)]);}

  // IA vende
  function iaVende(ts,m,vend){
    const novoTs=[...ts.map(t=>({...t,jogadores:[...t.jogadores]}))];
    const novoMkt={...m,...ORDEM.reduce((a,p)=>({...a,[p]:[...m[p]]}),{})};
    const novoVend={...vend};
    for(const t of novoTs){
      if(ctrlNomes.includes(t.nome)) continue;
      const jPos=t.jogadores.filter(j=>POS_MAP[j.posicao]===pos||j.posicao===pos);
      if(jPos.length>1){
        const pior=[...jPos].sort((a,b)=>a.ovr-b.ovr)[0];
        const preco=Math.max(20,Math.round(pior.ovr*0.8));
        t.jogadores=t.jogadores.filter(j=>j!==pior);
        t.saldo+=preco;
        novoMkt[pos]=[...novoMkt[pos],{jogador:pior,preco,clube_origem:t.nome,faixa:"livre",estrelas:pior.potencial||2}];
        novoVend[t.nome]=pos;
        addLog(`[IA] ${t.nome} vendeu ${pior.nome} (${pos} OVR:${pior.ovr}) por ${preco.toLocaleString("pt-BR")} pts`);
      }
    }
    return [novoTs,novoMkt,novoVend];
  }

  // IA compra
  function iaCompra(ts,m){
    const novoTs=[...ts.map(t=>({...t,jogadores:[...t.jogadores]}))];
    const novoMkt={...m,...ORDEM.reduce((a,p)=>({...a,[p]:[...m[p]]}),{})};
    for(const t of novoTs){
      if(ctrlNomes.includes(t.nome)) continue;
      const fila=novoMkt[pos].filter(e=>e.clube_origem!==t.nome&&e.preco<=t.saldo*0.6);
      if(!fila.length) continue;
      const melhor=fila.reduce((b,e)=>e.jogador.ovr>b.jogador.ovr?e:b);
      t.jogadores.push({...melhor.jogador});
      t.saldo-=melhor.preco;
      novoMkt[pos]=novoMkt[pos].filter(e=>e!==melhor);
      addLog(`[IA] ${t.nome} comprou ${melhor.jogador.nome} (${pos} OVR:${melhor.jogador.ovr}) por ${melhor.preco.toLocaleString("pt-BR")} pts`);
    }
    return [novoTs,novoMkt];
  }

  function avancarFaseVendas(){
    if(!iaDone){
      // Roda IA para esta posição
      const [nt,nm,nv]=iaVende(timesState,mkt,vendidos);
      setTimesState(nt);setMkt(nm);setVendidos(nv);setIaDone(true);
      // Se nenhum ctrl nesta pos, vai para compras
      const ctrlNestPos=ctrlNomes.filter(n=>nv[n]===pos);
      if(ctrlNestPos.length===0){
        const [nt2,nm2]=iaCompra(nt,nm);
        setTimesState(nt2);setMkt(nm2);
        proximaPos();
      }
      return;
    }
    // Todos ctrl já venderam — IA compra e avança
    const [nt2,nm2]=iaCompra(timesState,mkt);
    setTimesState(nt2);setMkt(nm2);
    proximaPos();
  }

  function proximaPos(){
    setIaDone(false);
    if(posIdx<ORDEM.length-1){
      setPosIdx(i=>i+1);
      setCtrlIdx(0);
      setFase("vendas");
    } else {
      // Fim — subida de base
      const novoTs=timesState.map(t=>{
        const vend=vendidos[t.nome];
        if(!vend) return t;
        const comprou=t.jogadores.some(j=>POS_MAP[j.posicao]===vend||j.posicao===vend);
        return t;
      });
      onFim(novoTs);
    }
  }

  const clubeAtual=timesState.find(t=>t.nome===ctrlNomes[ctrlIdx]);

  function handleVender(jogador,preco,posVenda){
    if(!clubeAtual) return;
    const novoTs=timesState.map(t=>{
      if(t.nome!==clubeAtual.nome) return t;
      return {...t,jogadores:t.jogadores.filter(j=>j!==jogador),saldo:t.saldo+preco};
    });
    const novoMkt={...mkt,[posVenda]:[...mkt[posVenda],{jogador,preco,clube_origem:clubeAtual.nome,faixa:"livre",estrelas:jogador.potencial||2}]};
    const novoVend={...vendidos,[clubeAtual.nome]:posVenda};
    addLog(`[MESTRE] ${clubeAtual.nome} vendeu ${jogador.nome} (${posVenda}) por ${preco.toLocaleString("pt-BR")} pts`,"mestre");
    setTimesState(novoTs);setMkt(novoMkt);setVendidos(novoVend);
    avancarCtrl(novoVend,novoTs,novoMkt);
  }

  function handlePularVenda(){
    avancarCtrl(vendidos,timesState,mkt);
  }

  function avancarCtrl(vend,ts,m){
    if(ctrlIdx<ctrlNomes.length-1){
      setCtrlIdx(i=>i+1);
    } else {
      // Todos ctrl passaram — IA vende e depois compras
      const [nt,nm,nv]=iaVende(ts,m,vend);
      setTimesState(nt);setMkt(nm);setVendidos(nv);setIaDone(true);
      setFase("compras");setCtrlIdx(0);
    }
  }

  function handleComprar(entrada){
    if(!clubeAtual) return;
    const novoTs=timesState.map(t=>{
      if(t.nome!==clubeAtual.nome) return t;
      return {...t,jogadores:[...t.jogadores,{...entrada.jogador}],saldo:t.saldo-entrada.preco};
    });
    const novoMkt={...mkt,[pos]:mkt[pos].filter(e=>e!==entrada)};
    addLog(`[MESTRE] ${clubeAtual.nome} comprou ${entrada.jogador.nome} (${pos} OVR:${entrada.jogador.ovr}) por ${entrada.preco.toLocaleString("pt-BR")} pts`,"mestre");
    setTimesState(novoTs);setMkt(novoMkt);
    avancarCtrlCompra(novoTs,novoMkt);
  }

  function handlePularCompra(){
    avancarCtrlCompra(timesState,mkt);
  }

  function avancarCtrlCompra(ts,m){
    const ctrlNestPos=ctrlNomes.filter(n=>vendidos[n]===pos);
    if(ctrlIdx<ctrlNestPos.length-1){
      setCtrlIdx(i=>i+1);
    } else {
      // IA compra e próxima posição
      const [nt2,nm2]=iaCompra(ts,m);
      setTimesState(nt2);setMkt(nm2);
      if(posIdx<ORDEM.length-1){
        setPosIdx(i=>i+1);setCtrlIdx(0);setFase("vendas");setIaDone(false);
      } else {
        onFim(nt2);
      }
    }
  }

  const ctrlNestPos=ctrlNomes.filter(n=>vendidos[n]===pos);
  const clubeCompraAtual=fase==="compras"?timesState.find(t=>t.nome===ctrlNestPos[ctrlIdx]):null;

  return(
    <div style={{display:"grid",gridTemplateColumns:"1fr 280px",gap:12}}>
      <div>
        <div style={{background:"#0d0d1a",border:"1px solid #2a2a3a",borderRadius:8,padding:"8px 14px",marginBottom:12,display:"flex",alignItems:"center",gap:12}}>
          {ORDEM.map((p,i)=>(
            <div key={p} style={{display:"flex",alignItems:"center",gap:6}}>
              <div style={{width:28,height:28,borderRadius:"50%",background:i<posIdx?"#10b981":i===posIdx?COR_POS[p]:"#2a2a3a",display:"flex",alignItems:"center",justifyContent:"center",fontSize:10,fontWeight:700,color:i<posIdx||i===posIdx?"#fff":"#475569"}}>{p}</div>
              {i<ORDEM.length-1&&<div style={{width:20,height:2,background:i<posIdx?"#10b981":"#2a2a3a"}}/>}
            </div>
          ))}
          <span style={{marginLeft:"auto",fontSize:12,color:"#64748b"}}>{fase==="vendas"?"Vendas":"Compras"}</span>
        </div>

        {fase==="vendas"&&clubeAtual&&(
          <TelaVenda clube={clubeAtual} mkt={mkt} onVender={handleVender} onPular={handlePularVenda}/>
        )}
        {fase==="vendas"&&!clubeAtual&&(
          <div style={{background:"#13131f",border:"1px solid #2a2a3a",borderRadius:10,padding:20,textAlign:"center"}}>
            <div style={{color:"#64748b",marginBottom:12}}>IA processando vendas de {pos}...</div>
            <button onClick={avancarFaseVendas} style={{background:"#3b82f6",color:"#fff",border:"none",borderRadius:6,padding:"8px 20px",cursor:"pointer",fontWeight:700}}>
              Avançar para Compras →
            </button>
          </div>
        )}
        {fase==="compras"&&clubeCompraAtual&&(
          <TelaCompra clube={clubeCompraAtual} pos={pos} mkt={mkt} onComprar={handleComprar} onPular={handlePularCompra}/>
        )}
        {fase==="compras"&&!clubeCompraAtual&&(
          <div style={{background:"#13131f",border:"1px solid #2a2a3a",borderRadius:10,padding:20,textAlign:"center"}}>
            <div style={{color:"#64748b",marginBottom:12}}>Nenhum time controlado vendeu {pos}.</div>
            <button onClick={()=>{
              const [nt2,nm2]=iaCompra(timesState,mkt);
              setTimesState(nt2);setMkt(nm2);
              if(posIdx<ORDEM.length-1){setPosIdx(i=>i+1);setCtrlIdx(0);setFase("vendas");setIaDone(false);}
              else onFim(nt2);
            }} style={{background:"#3b82f6",color:"#fff",border:"none",borderRadius:6,padding:"8px 20px",cursor:"pointer",fontWeight:700}}>
              Próxima posição →
            </button>
          </div>
        )}

        {/* Mercado atual */}
        <div style={{background:"#13131f",border:"1px solid #2a2a3a",borderRadius:10,padding:12,marginTop:12}}>
          <div style={{fontWeight:700,fontSize:13,marginBottom:8,color:"#f8fafc"}}>Mercado — {pos} ({(mkt[pos]||[]).length} disponíveis)</div>
          <div style={{display:"flex",flexDirection:"column",gap:3}}>
            {[...(mkt[pos]||[])].sort((a,b)=>b.jogador.ovr-a.jogador.ovr).slice(0,6).map((e,i)=>(
              <div key={i} style={{display:"flex",alignItems:"center",gap:8,padding:"4px 8px",background:"#1a1a2e",borderRadius:5}}>
                <span style={{fontSize:11,width:18,color:"#64748b"}}>{FAIXA_L[e.faixa]}</span>
                <span style={{fontSize:12}}>{ESTRELA[e.estrelas]}</span>
                <span style={{fontSize:12,flex:1,color:"#e2e8f0"}}>{e.jogador.nome}</span>
                <OvrBadge ovr={e.jogador.ovr}/>
                <span style={{fontSize:11,color:"#94a3b8"}}>{e.preco.toLocaleString("pt-BR")}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      {/* Log */}
      <div style={{background:"#13131f",border:"1px solid #2a2a3a",borderRadius:10,padding:12,maxHeight:600,overflowY:"auto"}}>
        <div style={{fontWeight:700,fontSize:12,marginBottom:8,color:"#f8fafc"}}>Log</div>
        {log.map((l,i)=>(
          <div key={i} style={{fontSize:11,padding:"3px 0",borderBottom:"1px solid #1a1a2e",
            color:l.tipo==="mestre"?"#f59e0b":l.tipo==="ia"?"#60a5fa":"#10b981"}}>
            {l.msg}
          </div>
        ))}
      </div>
    </div>
  );
}


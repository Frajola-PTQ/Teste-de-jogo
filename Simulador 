// MAIN APP
// ══════════════════════════════════════════════════════════════════════════════
export default function App(){
  const [tela,setTela]=useState("config"); // config|jogo|mercado|elenco|tabela
  const [timesCtrl,setTimesCtrl]=useState(["Flamengo"]);
  const [times,setTimes]=useState(()=>TIMES_INIT.map(t=>({...t})));
  const [rodada,setRodada]=useState(0);
  const [calendario]=useState(()=>gerarCalendario(TIMES_INIT));
  const [resultados,setResultados]=useState([]);
  const [clubeSel,setClubeSel]=useState(null);
  const [editJog,setEditJog]=useState(null);

  const s={
    wrap:{minHeight:"100vh",background:"#080810",color:"#e2e8f0",fontFamily:"'Segoe UI',system-ui,sans-serif"},
    nav:{background:"#0d0d1a",borderBottom:"1px solid #1e1e3a",display:"flex",alignItems:"center",gap:4,padding:"8px 16px"},
    navBtn:(t)=>({background:tela===t?"#3b82f6":"transparent",color:tela===t?"#fff":"#64748b",border:"none",borderRadius:6,padding:"6px 14px",cursor:"pointer",fontWeight:600,fontSize:13}),
    card:{background:"#13131f",border:"1px solid #1e1e3a",borderRadius:10,padding:16,marginBottom:12},
    btn:(c)=>({background:c||"#3b82f6",color:"#fff",border:"none",borderRadius:6,padding:"7px 16px",cursor:"pointer",fontWeight:700,fontSize:13}),
  };

  function simularRodada(){
    if(rodada>=calendario.length) return;
    const jog=calendario[rodada];
    const novosTimes=[...times.map(t=>({...t,estatisticas:{...t.estatisticas}}))];
    const novosRes=[];
    for(const [ai,bi] of jog){
      const a=novosTimes[ai],b=novosTimes[bi];
      const [ga,gb]=simPartida(a,b);
      a.estatisticas.gols_pro+=ga;a.estatisticas.gols_contra+=gb;
      b.estatisticas.gols_pro+=gb;b.estatisticas.gols_contra+=ga;
      if(ga>gb){a.estatisticas.pontos+=3;a.estatisticas.vitorias++;b.estatisticas.derrotas++;}
      else if(ga<gb){b.estatisticas.pontos+=3;b.estatisticas.vitorias++;a.estatisticas.derrotas++;}
      else{a.estatisticas.pontos++;b.estatisticas.pontos++;a.estatisticas.empates++;b.estatisticas.empates++;}
      novosRes.push({a:a.nome,b:b.nome,ga,gb});
    }
    setTimes(novosTimes);
    setResultados(r=>[...r,{rodada:rodada+1,jogos:novosRes}]);
    setRodada(r=>r+1);
  }

  const tabela=[...times].sort((a,b)=>
    b.estatisticas.pontos-a.estatisticas.pontos||
    (b.estatisticas.gols_pro-b.estatisticas.gols_contra)-(a.estatisticas.gols_pro-a.estatisticas.gols_contra)||
    b.estatisticas.gols_pro-a.estatisticas.gols_pro
  );

  return(
    <div style={s.wrap}>
      <div style={s.nav}>
        <span style={{fontWeight:800,fontSize:16,color:"#f8fafc",marginRight:8}}>⚽ FM BR</span>
        {tela!=="config"&&<>
          <button style={s.navBtn("jogo")} onClick={()=>setTela("jogo")}>Rodadas</button>
          <button style={s.navBtn("tabela")} onClick={()=>setTela("tabela")}>Tabela</button>
          <button style={s.navBtn("elenco")} onClick={()=>setTela("elenco")}>Elencos</button>
          <button style={s.navBtn("mercado")} onClick={()=>setTela("mercado")}>Mercado</button>
        </>}
        <span style={{marginLeft:"auto",fontSize:12,color:"#475569"}}>Rodada {rodada}/{calendario.length}</span>
      </div>

      <div style={{padding:16}}>

        {/* CONFIG */}
        {tela==="config"&&(
          <div style={{maxWidth:600,margin:"0 auto"}}>
            <div style={{fontSize:24,fontWeight:800,color:"#f8fafc",marginBottom:4}}>Football Master Brasil</div>
            <div style={{color:"#64748b",marginBottom:20}}>Simulador de temporada — Brasileirão</div>
            <div style={s.card}>
              <div style={{fontWeight:700,marginBottom:10}}>Seus times (controle total)</div>
              <div style={{display:"flex",flexWrap:"wrap",gap:6,marginBottom:16}}>
                {TIMES_INIT.map(t=>(
                  <button key={t.nome} onClick={()=>setTimesCtrl(p=>p.includes(t.nome)?p.filter(x=>x!==t.nome):[...p,t.nome])} style={{
                    background:timesCtrl.includes(t.nome)?"#3b82f6":"#1e1e2e",
                    color:timesCtrl.includes(t.nome)?"#fff":"#64748b",
                    border:`1px solid ${timesCtrl.includes(t.nome)?"#3b82f6":"#2a2a3a"}`,
                    borderRadius:6,padding:"5px 12px",cursor:"pointer",fontWeight:600,fontSize:12
                  }}>{t.nome}</button>
                ))}
              </div>
              <div style={{fontSize:12,color:"#475569",marginBottom:16}}>{timesCtrl.length} time(s) selecionado(s)</div>
              <button style={s.btn("#10b981")} onClick={()=>setTela("jogo")}>
                Iniciar Temporada →
              </button>
            </div>
          </div>
        )}

        {/* RODADAS */}
        {tela==="jogo"&&(
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12}}>
            <div>
              <div style={s.card}>
                <div style={{fontWeight:700,marginBottom:10,fontSize:15}}>Rodada {rodada+1} / {calendario.length}</div>
                {rodada<calendario.length?(
                  <>
                    <div style={{display:"flex",flexDirection:"column",gap:4,marginBottom:12}}>
                      {calendario[rodada]?.map(([ai,bi],i)=>(
                        <div key={i} style={{display:"flex",alignItems:"center",justifyContent:"space-between",padding:"6px 10px",background:"#1a1a2e",borderRadius:6}}>
                          <span style={{fontSize:13,fontWeight:timesCtrl.includes(times[ai]?.nome)?700:400,color:timesCtrl.includes(times[ai]?.nome)?"#f59e0b":"#e2e8f0"}}>{times[ai]?.nome}</span>
                          <span style={{color:"#475569",fontSize:12}}>vs</span>
                          <span style={{fontSize:13,fontWeight:timesCtrl.includes(times[bi]?.nome)?700:400,color:timesCtrl.includes(times[bi]?.nome)?"#f59e0b":"#e2e8f0"}}>{times[bi]?.nome}</span>
                        </div>
                      ))}
                    </div>
                    <button style={s.btn()} onClick={simularRodada}>Simular Rodada →</button>
                  </>
                ):<div style={{color:"#10b981",fontWeight:700}}>Temporada encerrada! Vá ao Mercado para contratar.</div>}
              </div>
            </div>
            <div>
              {resultados.slice(-3).reverse().map((r,ri)=>(
                <div key={ri} style={{...s.card,marginBottom:8}}>
                  <div style={{fontWeight:700,fontSize:12,color:"#64748b",marginBottom:6}}>Rodada {r.rodada}</div>
                  {r.jogos.map((j,i)=>(
                    <div key={i} style={{display:"flex",justifyContent:"space-between",alignItems:"center",padding:"3px 0",borderBottom:"1px solid #1e1e2e",fontSize:12}}>
                      <span style={{flex:1,textAlign:"right",color:timesCtrl.includes(j.a)?"#f59e0b":"#e2e8f0"}}>{j.a}</span>
                      <span style={{margin:"0 10px",fontWeight:700,color:"#f8fafc"}}>{j.ga} – {j.gb}</span>
                      <span style={{flex:1,color:timesCtrl.includes(j.b)?"#f59e0b":"#e2e8f0"}}>{j.b}</span>
                    </div>
                  ))}
                </div>
              ))}
            </div>
          </div>
        )}

        {/* TABELA */}
        {tela==="tabela"&&(
          <div style={s.card}>
            <div style={{fontWeight:800,fontSize:15,marginBottom:12}}>Classificação — Brasileirão</div>
            <table style={{width:"100%",borderCollapse:"collapse"}}>
              <thead>
                <tr style={{fontSize:11,color:"#64748b",borderBottom:"1px solid #2a2a3a"}}>
                  {["#","Time","Pts","J","V","E","D","GP","GC","SG"].map(h=>(
                    <td key={h} style={{padding:"4px 8px",textAlign:h==="#"||h==="Time"?"left":"center"}}>{h}</td>
                  ))}
                </tr>
              </thead>
              <tbody>
                {tabela.map((t,i)=>{
                  const st=t.estatisticas;
                  const j=st.vitorias+st.empates+st.derrotas;
                  const sg=st.gols_pro-st.gols_contra;
                  const isCtrl=timesCtrl.includes(t.nome);
                  return(
                    <tr key={t.nome} style={{borderBottom:"1px solid #1a1a2e",background:isCtrl?"#1a1a2a":"transparent"}}>
                      <td style={{padding:"6px 8px",color:"#64748b",fontSize:12}}>{i+1}</td>
                      <td style={{padding:"6px 8px",fontWeight:isCtrl?700:400,color:isCtrl?"#f59e0b":"#e2e8f0",fontSize:13}}>{t.nome}</td>
                      <td style={{padding:"6px 8px",textAlign:"center",fontWeight:700,color:"#10b981"}}>{st.pontos}</td>
                      <td style={{padding:"6px 8px",textAlign:"center",fontSize:12,color:"#94a3b8"}}>{j}</td>
                      <td style={{padding:"6px 8px",textAlign:"center",fontSize:12,color:"#94a3b8"}}>{st.vitorias}</td>
                      <td style={{padding:"6px 8px",textAlign:"center",fontSize:12,color:"#94a3b8"}}>{st.empates}</td>
                      <td style={{padding:"6px 8px",textAlign:"center",fontSize:12,color:"#94a3b8"}}>{st.derrotas}</td>
                      <td style={{padding:"6px 8px",textAlign:"center",fontSize:12,color:"#94a3b8"}}>{st.gols_pro}</td>
                      <td style={{padding:"6px 8px",textAlign:"center",fontSize:12,color:"#94a3b8"}}>{st.gols_contra}</td>
                      <td style={{padding:"6px 8px",textAlign:"center",fontSize:12,color:sg>0?"#10b981":sg<0?"#ef4444":"#94a3b8"}}>{sg>0?"+":""}{sg}</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        )}

        {/* ELENCOS */}
        {tela==="elenco"&&(
          <div style={{display:"grid",gridTemplateColumns:"220px 1fr",gap:12}}>
            <div style={{display:"flex",flexDirection:"column",gap:4}}>
              {times.map(t=>(
                <button key={t.nome} onClick={()=>{setClubeSel(t.nome);setEditJog(null)}} style={{
                  background:clubeSel===t.nome?"#1e3a5f":"#13131f",
                  border:`1px solid ${clubeSel===t.nome?"#3b82f6":"#1e1e3a"}`,
                  color:timesCtrl.includes(t.nome)?"#f59e0b":"#e2e8f0",
                  borderRadius:6,padding:"7px 12px",cursor:"pointer",textAlign:"left",fontSize:13,fontWeight:timesCtrl.includes(t.nome)?700:400
                }}>
                  {timesCtrl.includes(t.nome)?"★ ":""}{t.nome}
                  <span style={{float:"right",fontSize:11,color:"#475569"}}>{Math.round(t.jogadores.reduce((s,j)=>s+j.ovr,0)/(t.jogadores.length||1))}</span>
                </button>
              ))}
            </div>
            {clubeSel&&(()=>{
              const t=times.find(x=>x.nome===clubeSel);
              if(!t) return null;
              return(
                <div style={s.card}>
                  <div style={{display:"flex",justifyContent:"space-between",marginBottom:12}}>
                    <div>
                      <div style={{fontWeight:800,fontSize:16}}>{t.nome}</div>
                      <div style={{fontSize:12,color:"#64748b"}}>Saldo: {t.saldo.toLocaleString("pt-BR")} pts · {t.jogadores.length} jogadores</div>
                    </div>
                  </div>
                  {ORDEM.map(pos=>{
                    const jogs=t.jogadores.filter(j=>POS_MAP[j.posicao]===pos||j.posicao===pos);
                    return jogs.length>0&&(
                      <div key={pos} style={{marginBottom:10}}>
                        <div style={{display:"flex",alignItems:"center",gap:6,marginBottom:4}}><Badge pos={pos}/></div>
                        {[...jogs].sort((a,b)=>b.ovr-a.ovr).map((j,i)=>(
                          <div key={i} style={{display:"flex",alignItems:"center",gap:8,padding:"5px 8px",background:"#1a1a2e",borderRadius:5,marginBottom:2}}>
                            {editJog===j?(
                              <div style={{display:"flex",gap:6,flex:1,alignItems:"center"}}>
                                <span style={{fontSize:12,color:"#94a3b8",width:160}}>{j.nome}</span>
                                <input defaultValue={j.ovr} onBlur={e=>{
                                  const v=parseInt(e.target.value);
                                  if(!isNaN(v)&&v>=50&&v<=99){
                                    setTimes(ts=>ts.map(tm=>tm.nome!==t.nome?tm:{...tm,jogadores:tm.jogadores.map(jj=>jj===j?{...jj,ovr:v}:jj)}));
                                  }
                                }} style={{width:50,background:"#0d0d1a",border:"1px solid #3b82f6",borderRadius:4,color:"#e2e8f0",padding:"2px 6px",fontSize:12}}/>
         <input defaultValue={j.idade||25} onBlur={e=>{
                                  const v=parseInt(e.target.value);
                                  if(!isNaN(v)&&v>=15&&v<=45){
                                    setTimes(ts=>ts.map(tm=>tm.nome!==t.nome?tm:{...tm,jogadores:tm.jogadores.map(jj=>jj===j?{...jj,idade:v}:jj)}));
                                  }
                                }} style={{width:40,background:"#0d0d1a",border:"1px solid #3b82f6",borderRadius:4,color:"#e2e8f0",padding:"2px 6px",fontSize:12}}/>
                                <button onClick={()=>setEditJog(null)} style={{background:"#10b981",color:"#fff",border:"none",borderRadius:4,padding:"2px 8px",cursor:"pointer",fontSize:11}}>OK</button>
                              </div>
                            ):(
                              <>
                                <span style={{fontSize:13,flex:1,fontWeight:500}}>{j.nome}</span>
                                <span style={{fontSize:11,color:"#64748b"}}>{j.idade||"?"}a</span>
                                <OvrBadge ovr={j.ovr}/>
                                {timesCtrl.includes(t.nome)&&<button onClick={()=>setEditJog(j)} style={{background:"#2a2a3a",color:"#94a3b8",border:"none",borderRadius:4,padding:"2px 8px",cursor:"pointer",fontSize:11}}>Editar</button>}
                              </>
                            )}
                          </div>
                        ))}
                      </div>
                    );
                  })}
                </div>
              );
            })()}
          </div>
        )}

        {/* MERCADO */}
        {tela==="mercado"&&(
          <TelaMercado
            times={times}
            timesCtrl={timesCtrl}
            onFim={novosTimes=>{
              setTimes(novosTimes);
              setTela("jogo");
            }}
          />
        )}

      </div>
    </div>
  );
}
  